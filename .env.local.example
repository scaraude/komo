NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL publique du site (sert à bâtir l'URL absolue de l'image OG de partage)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Autocomplete de destination (proxifié côté serveur via /api/places)
# Clé gratuite sur https://www.geoapify.com (3000 req/jour, sans carte bancaire)
# Optionnelle en dev (l'autocomplete dégrade en 503), requise en prod/preview.
GEOAPIFY_API_KEY=your-geoapify-key
